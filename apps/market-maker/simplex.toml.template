[simplex]
maxConcurrentOrders = 5
logging = "info"
# Required for HyperFX solver selection auction
substratePrivateKey = "__SUBSTRATE_PRIVATE_KEY__"
hyperbridgeWsUrl = "wss://nexus.ibp.network"

[simplex.queue]
maxRechecks = 10
recheckDelayMs = 30000

[simplex.signer]
type = "privateKey"
key = "__SIGNER_PRIVATE_KEY__"

[[chains]]
chainId = "EVM-8453"
rpcUrl = "__BASE_RPC_URL__"
bundlerUrl = "__BUNDLER_URL__"

# ---------------------------------------------------------------
# HyperFX strategies: generated at startup from active pairs in
# the SimpleFX portal. One [[strategies]] block per active pair.
# To add a new pair: insert a row in lp_fx_pairs and restart.
# ---------------------------------------------------------------

__STRATEGIES__

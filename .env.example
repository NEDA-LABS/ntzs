# =========================
# Global
# =========================
NODE_ENV=development

# Used for local development convenience. In production, use a proper secret store.
# Keep this value secret.
APP_SECRET=replace_me_with_long_random_string

# =========================
# Database (Neon Postgres)
# =========================
# Example: postgres://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# Optional: a separate DB URL for the worker if you prefer.
WORKER_DATABASE_URL=

# =========================
# Neon Auth
# =========================
# Neon Auth base URL from Neon Console.
NEON_AUTH_URL=https://replace-me.neon.tech

# Comma-separated list of emails that should be automatically upgraded to super_admin
BOOTSTRAP_SUPER_ADMIN_EMAIL=

# If Neon Auth provides public/secret keys for server-side verification, put them here.
# (Leave blank if not required by your chosen integration method.)
NEON_AUTH_PUBLIC_KEY=
NEON_AUTH_SECRET_KEY=

# Next.js
# If you later host on Vercel/etc., set this to the full canonical URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FX_URL=http://localhost:3001

# Client-side blockchain config (baked into the Next.js bundle at build time)
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_NTZS_CONTRACT_ADDRESS_BASE=

# =========================
# Coinbase CDP (embedded-wallet auth)
# =========================
# ES256 keypair (JWK) used to sign the JWTs that authenticate users to their
# Coinbase CDP embedded wallets. REQUIRED whenever any wallet has
# provider = 'coinbase_embedded'. There is NO built-in/default key — the app
# fails closed if these are unset. Generate a dedicated keypair, register the
# PUBLIC jwk with your CDP project, and keep the PRIVATE jwk secret.
#   node -e "(async()=>{const {generateKeyPair,exportJWK}=require('jose');const {publicKey,privateKey}=await generateKeyPair('ES256',{extractable:true});const pub=await exportJWK(publicKey),prv=await exportJWK(privateKey);const kid='cdp-key-1';console.log('CDP_JWT_PRIVATE_KEY_JWK='+JSON.stringify({...prv,alg:'ES256',use:'sig',kid}));console.log('CDP_JWT_PUBLIC_KEY_JWK='+JSON.stringify({...pub,alg:'ES256',use:'sig',kid}));console.log('CDP_JWT_KID='+kid);})()"
CDP_JWT_PRIVATE_KEY_JWK=
CDP_JWT_PUBLIC_KEY_JWK=
CDP_JWT_KID=cdp-key-1

# =========================
# AWS (S3 for KYC documents)
# =========================
AWS_REGION=eu-west-1
S3_BUCKET_KYC=replace-me-kyc-bucket

# For local development you can use static credentials.
# Prefer IAM roles in production.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: if using temporary credentials
AWS_SESSION_TOKEN=

# =========================
# Chain RPC (Alchemy or other provider)
# =========================
# Base mainnet
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/REPLACE_ME
# BNB Smart Chain mainnet
BNB_RPC_URL=https://bnb-mainnet.g.alchemy.com/v2/REPLACE_ME

# =========================
# Minting / Worker settings
# =========================
# Daily issuance cap in TZS (initially 100,000,000)
DAILY_ISSUANCE_CAP_TZS=100000000

# Worker polling interval
WORKER_POLL_INTERVAL_MS=5000

# Chain selection defaults (optional)
DEFAULT_ISSUANCE_CHAIN=base

# WARNING: Do not commit private keys.
# MVP only: server-side minter key used by the worker to send mint transactions.
MINTER_PRIVATE_KEY=

# Address that receives withdrawal platform fees (minted on burn).
# Used as fallback when a burn is not tied to a partner with its own
# treasury_wallet_address. Leave blank to keep fees as implicit reserve surplus.
PLATFORM_TREASURY_ADDRESS=

# Payout-engine burn signer (/api/cron/process-burns): BURNER_PRIVATE_KEY,
# falling back to MINTER_PRIVATE_KEY. The signer must hold BURNER_ROLE on the
# token or burns fail closed (marked failed with the error, auditable).
# BURNER_PRIVATE_KEY=

# Merchants are NEDApay users: new stores are created via the NEDApay app
# (Biashara service API), where the owner is already NIDA-verified. The
# standalone merchant-portal signup (which auto-provisioned an HD wallet on
# first OTP login with no KYC) is CLOSED unless this is exactly 'true'.
# Existing merchants sign in unaffected.
MERCHANT_SELF_SIGNUP_ENABLED=

# Direct-app sign-ups (ntzs.co.tz/app) — the BoT sandbox pilot is capped at
# 100 participants, so NEW sign-ups are CLOSED and handed off to the NEDApay
# app (https://app.nedapay.xyz/) unless this is exactly 'true'. Existing
# users sign in and transact unchanged, and existing wallet holders can still
# complete NIDA verification (retro-KYC). Gates the sign-up page, the wallet
# activation screen, and the NIDA verify action.
DIRECT_APP_SIGNUP_ENABLED=

# =========================
# KYC — Selcom Identity (NIDA lookup, BoT Parameter 8)
# =========================
# Verifies NIDA numbers so new wallets can be issued while WALLET_CREATION_PAUSED.
# Fail-closed: unset means identity verification is unavailable and NO new
# wallet can be approved. Get credentials from Selcom; store ONLY here (never
# in code), scope to Production AND Preview in Vercel, and rotate any pair
# that was ever shared over chat.
SELCOM_IDENTITY_URL=https://identity.selcommobile.com/api/v2
SELCOM_IDENTITY_API_KEY=
SELCOM_IDENTITY_API_SECRET=

# ERC-20 contract addresses per chain
NTZS_CONTRACT_ADDRESS_BASE=
NTZS_CONTRACT_ADDRESS_BNB=

# =========================
# PSP Routing
# =========================
# Controls which PSP handles mobile money (on-ramp + off-ramp).
# Set to 'azampay' only after sandbox testing is complete.
# Card payments always use Snippe regardless of this value.
ACTIVE_MOBILE_PSP=snippe

# ── Multi-rail routing (optional; unset = single rail from ACTIVE_MOBILE_PSP) ──
# Priority-ordered, comma-separated rails; initiation fails over down the list
# so one PSP outage never blocks users. Rails: snippe | azampay | selcom
# (selcom activates when its adapter lands — docs/selcom-integration-spec.md).
# AzamPay is auto-skipped for Vodacom M-Pesa collections until their Vodacom
# onboarding completes.
COLLECTION_RAIL_PRIORITY=
# Per-network overrides (optional), e.g. COLLECTION_RAILS_VODACOM=snippe
COLLECTION_RAILS_VODACOM=
COLLECTION_RAILS_AIRTEL=
COLLECTION_RAILS_TIGO=
COLLECTION_RAILS_HALOTEL=
COLLECTION_RAILS_TTCL=
DISBURSEMENT_RAIL_PRIORITY=
# AzamPay payouts stay OFF until their IP-whitelisting requirement is resolved
# (static egress). Exactly 'true' enables them in disbursement plans.
AZAMPAY_DISBURSEMENT_ENABLED=
# Burn gate: the burn engine refuses to burn while no disbursement rail passes
# a live health probe (irreversible burns must not outrun the cash leg).
# Exactly 'true' disables the gate — emergency use only.
BURN_GATE_DISABLED=

# =========================
# AzamPay (Mobile Money PSP — active for mobile on-ramp + off-ramp)
# =========================
# Credentials from AzamPay sandbox/production portal
AZAMPAY_APP_NAME=
AZAMPAY_CLIENT_ID=
AZAMPAY_CLIENT_SECRET=
# HMAC secret for verifying AzamPay webhooks (verify signing scheme in sandbox portal)
AZAMPAY_WEBHOOK_SECRET=

# Production checksum key (RSA PUBLIC key PEM, base64-encoded to survive env
# storage: `base64 -w0 their-key.pem`). Signs name-lookup and disbursement
# requests per AzamPay's scheme: base64(RSA_PKCS1(pubkey, SHA512(concat))).
# Unset = checksum omitted (sandbox behaviour). Production key + source
# account arrive with production credentials.
AZAMPAY_CHECKSUM_PUBLIC_KEY_B64=
# Our production disbursement source account (assigned by AzamPay at go-live);
# part of the disbursement checksum input.
AZAMPAY_SOURCE_ACCOUNT=
# Float bank to disburse from: 'nmb' | 'crdb'
AZAMPAY_BANK_NAME=nmb
# Environment: 'sandbox' | 'production'
AZAMPAY_ENV=sandbox

# =========================
# Snippe (Card payments only — mobile money now handled by AzamPay)
# =========================
# Bearer token for Snippe API (still used for snippe_card payment type)
SNIPPE_API_KEY=
# HMAC secret for verifying Snippe webhooks (starts with whsec_)
SNIPPE_WEBHOOK_SECRET=

# =========================
# Selcom Business API (custodian bank + PSP — collections, payouts, balance/statement)
# =========================
# Adapter is fully capability-gated: with the flags below unset, Selcom never
# appears in a rail plan and its webhooks/cron no-op, so these can be filled
# incrementally. GO-LIVE ORDER: (1) rotate any credentials that were ever
# shared over WhatsApp/email and store the rotated pair ONLY in Vercel,
# (2) apply drizzle/0061_selcom_provider.sql manually in Neon (adds the
# 'selcom' enum value), (3) resolve IP whitelisting — Selcom rejects calls
# from non-whitelisted IPs with error 611, and Vercel egress IPs are dynamic,
# so production calls need the static-egress relay, (4) flip the flags and
# add 'selcom' to COLLECTION_RAIL_PRIORITY / DISBURSEMENT_RAIL_PRIORITY.
# 'sandbox' | 'production' — picks the Selcom base URL
SELCOM_ENV=sandbox
# Override base URL (e.g. a pre-live URL from Selcom, or if the gateway path
# differs from the default sandbox.selcom.business / api.selcom.business)
SELCOM_BIZ_BASE_URL=
# API key issued by Selcom (goes in the 'api-key' request header)
SELCOM_API_KEY=
# OUR RSA private key for request signing (RSA-SHA256 over the ordered field
# string). Raw PEM or base64-encoded PEM (`base64 -w0 key.pem`) — base64 is
# safer for env storage since PEMs are multi-line.
SELCOM_PRIVATE_KEY=
# Our Selcom business account number (spaces tolerated; used for balance,
# statement, and as the payout source)
SELCOM_ACCOUNT_NUMBER=
# Utility reference for push-USSD collections (assigned by Selcom — confirm
# exact semantics with them before enabling collections; REQUIRED, no default)
SELCOM_UTILITY_REF=
# Payout purpose code (default 'FT' = funds transfer)
SELCOM_DEFAULT_PURPOSE=
# Override the disbursement path if Selcom's pre-live docs differ from
# /v1/transaction/process
SELCOM_DISBURSE_PATH=
# Exactly 'true' logs full request/response bodies (NEVER in production)
SELCOM_DEBUG=
# Capability flags — exactly 'true' enables the rail in routing plans and
# un-gates the webhook + poll-selcom cron. Credentials alone do nothing.
SELCOM_COLLECTIONS_ENABLED=
SELCOM_DISBURSEMENTS_ENABLED=
# ── W2B (Lipa Namba) deposits — works TODAY, independent of push-USSD ──
# The user pays our Lipa Namba from their own mobile-money menu; the
# selcom-statement-sync cron (every 5 min) ingests statement credits into the
# orphan ledger and auto-matches them to open intents by exact amount + payer
# phone. Needs the Selcom credentials above (statement API) and, like every
# 'selcom' write path, drizzle/0061 applied first. Exactly 'true' + a Lipa
# Namba below enables the deposit option in the app and the partner API.
SELCOM_W2B_ENABLED=
# The business number users pay to (shown in payment instructions)
SELCOM_LIPA_NAMBA=
# Account name shown next to the number so payers can confirm the right till
SELCOM_LIPA_NAME=

# =========================
# WaaS API
# =========================
# ── Withdrawal quotes (name + fee disclosure contract) ──
# HMAC secret signing withdrawal quote tokens (openssl rand -hex 32).
# Falls back to FX_JWT_SECRET when unset; if neither exists the quote
# endpoint returns 503 (fail closed).
WAAS_QUOTE_SECRET=
# Exactly 'true' → POST /api/v1/withdrawals REJECTS requests without a valid
# quoteId, guaranteeing every client fetched recipient name + fees first.
# Flip ONLY after partners (NEDApay) have adopted the quote step, or their
# cash-out breaks.
WAAS_REQUIRE_QUOTE=
# Public URL of the nTZS WaaS API (used for webhook URLs + apps/fx → apps/web minting rails)
# Local dev: http://localhost:3000
# Production: https://www.ntzs.co.tz  ← must use www, not bare ntzs.co.tz
NTZS_API_BASE_URL=http://localhost:3000

# AES-256 encryption key for partner HD wallet seeds (64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WAAS_ENCRYPTION_KEY=

# Private key of the platform relayer wallet used to prefund new user wallets with ETH for gas.
# On Base mainnet, 0.0005 ETH per user covers ~500 ERC-20 transfers.
# Generate a dedicated wallet: node -e "const {ethers}=require('ethers');const w=ethers.Wallet.createRandom();console.log('address:',w.address,'key:',w.privateKey)"
# WARNING: Fund this wallet with ETH and keep this key secret.
RELAYER_PRIVATE_KEY=

# Base Sepolia testnet RPC (for WaaS development)
BASE_SEPOLIA_RPC_URL=

# =========================
# Block Explorer API Keys
# =========================
# Get from https://basescan.org/myapikey
BASESCAN_API_KEY=

# =========================
# Internal service-to-service secret (apps/fx → apps/web LP mint endpoint)
# Generate: openssl rand -hex 32
INTERNAL_API_SECRET=

# =========================
# Resend (transactional email for SimpleFX OTP)
# Get API key at https://resend.com
RESEND_API_KEY=
RESEND_FROM=SimpleFX <noreply@ntzs.co.tz>

# Daily 10:00 EAT reserve attestation recipients (BoT sandbox Parameter 7/16).
# Comma-separated; falls back to the FX pool-alert recipients when unset.
# Production includes the BoT supervision contacts, e.g.:
#   ops@nedapay.xyz,Given.Mhema@bot.go.tz,january.bura@bot.go.tz
ATTESTATION_RECIPIENTS=
# Ops-only audience for INCOMPLETE-reading alerts (plumbing failures) AND the
# daily internal reconciliation copy (full annex: adjusted coverage, residual).
# The regulator list above receives the classic (a)-(d) attestation and
# NOTHING else. Falls back to the FX pool-alert recipients when unset — set it
# explicitly in production, e.g. ops@nedapay.xyz,devops@nedapay.xyz
ATTESTATION_INTERNAL_RECIPIENTS=
# Exactly 'true' promotes the reconciliation annex INTO the regulator email.
# Keep unset until the residual is understood and stable — the annex is an
# internal instrument until we choose to publish it from strength.
ATTESTATION_ANNEX_TO_REGULATOR=
# TZS held in government securities (T-bills); cash-only phase → leave 0/unset.
ATTESTATION_GOVT_SECURITIES_TZS=
# AzamPay reserve pot in the attestation (annex label shows the trust class):
#   book (default) — derived from our ledger of confirmed AzamPay deposits,
#                    minus ATTESTATION_AZAMPAY_SETTLED_TZS; labeled book-derived
#   api            — live GET /disbursement/checkbalance. Flip ONLY after
#                    AzamPay confirms it reflects the collection balance AND
#                    our static egress IP is whitelisted (otherwise the daily
#                    report goes INCOMPLETE instead of attesting).
#   off            — omit the pot entirely
ATTESTATION_AZAMPAY_MODE=
# Cumulative TZS already settled OUT of AzamPay (manual withdrawals to bank).
# Subtracted from the book-derived pot; update it each time a settlement runs.
ATTESTATION_AZAMPAY_SETTLED_TZS=

# =========================
# Merchant Portal
# =========================
# JWT secret for merchant session cookies (generate: openssl rand -hex 32)
# Falls back to FX_JWT_SECRET if not set, but set this explicitly in production.
MERCHANT_JWT_SECRET=

# BIP-39 mnemonic for merchant HD wallet derivation (path m/44'/8453'/2'/0/{index})
# WARNING: Never commit this value. Back it up securely.
MERCHANT_HD_MNEMONIC=

# =========================
# Enterprise Portal (Ramani / Advent)
# =========================
# JWT secret for enterprise session cookies — MUST be different from MERCHANT_JWT_SECRET
# Generate: openssl rand -hex 32
ENTERPRISE_JWT_SECRET=

# =========================
# SimpleFX LP Dashboard
# =========================
# JWT secret for LP session cookies (generate: openssl rand -hex 32)
FX_JWT_SECRET=

# BIP-39 mnemonic for LP wallet HD derivation (path m/44'/8453'/1'/0/{index})
# Generate: node -e "const {ethers}=require('ethers');console.log(ethers.Wallet.createRandom().mnemonic.phrase)"
# WARNING: Never commit this value. Back it up securely.
FX_HD_MNEMONIC=

# SMTP for OTP emails — works with Gmail, Outlook, or any mail server
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use an App Password (not your main password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Optional: override the From address shown to recipients
SMTP_FROM=SimpleFX <noreply@yourdomain.com>

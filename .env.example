# =========================
# Global
# =========================
NODE_ENV=development

# Used for local development convenience. In production, use a proper secret store.
# Keep this value secret.
APP_SECRET=replace_me_with_long_random_string

# =========================
# Database (Neon Postgres)
# =========================
# Example: postgres://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# Optional: a separate DB URL for the worker if you prefer.
WORKER_DATABASE_URL=

# =========================
# Neon Auth
# =========================
# Neon Auth base URL from Neon Console.
NEON_AUTH_URL=https://replace-me.neon.tech

# Comma-separated list of emails that should be automatically upgraded to super_admin
BOOTSTRAP_SUPER_ADMIN_EMAIL=

# If Neon Auth provides public/secret keys for server-side verification, put them here.
# (Leave blank if not required by your chosen integration method.)
NEON_AUTH_PUBLIC_KEY=
NEON_AUTH_SECRET_KEY=

# Next.js
# If you later host on Vercel/etc., set this to the full canonical URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FX_URL=http://localhost:3001

# Client-side blockchain config (baked into the Next.js bundle at build time)
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_NTZS_CONTRACT_ADDRESS_BASE=

# =========================
# Coinbase CDP (embedded-wallet auth)
# =========================
# ES256 keypair (JWK) used to sign the JWTs that authenticate users to their
# Coinbase CDP embedded wallets. REQUIRED whenever any wallet has
# provider = 'coinbase_embedded'. There is NO built-in/default key — the app
# fails closed if these are unset. Generate a dedicated keypair, register the
# PUBLIC jwk with your CDP project, and keep the PRIVATE jwk secret.
#   node -e "(async()=>{const {generateKeyPair,exportJWK}=require('jose');const {publicKey,privateKey}=await generateKeyPair('ES256',{extractable:true});const pub=await exportJWK(publicKey),prv=await exportJWK(privateKey);const kid='cdp-key-1';console.log('CDP_JWT_PRIVATE_KEY_JWK='+JSON.stringify({...prv,alg:'ES256',use:'sig',kid}));console.log('CDP_JWT_PUBLIC_KEY_JWK='+JSON.stringify({...pub,alg:'ES256',use:'sig',kid}));console.log('CDP_JWT_KID='+kid);})()"
CDP_JWT_PRIVATE_KEY_JWK=
CDP_JWT_PUBLIC_KEY_JWK=
CDP_JWT_KID=cdp-key-1

# =========================
# AWS (S3 for KYC documents)
# =========================
AWS_REGION=eu-west-1
S3_BUCKET_KYC=replace-me-kyc-bucket

# For local development you can use static credentials.
# Prefer IAM roles in production.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: if using temporary credentials
AWS_SESSION_TOKEN=

# =========================
# Chain RPC (Alchemy or other provider)
# =========================
# Base mainnet
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/REPLACE_ME
# BNB Smart Chain mainnet
BNB_RPC_URL=https://bnb-mainnet.g.alchemy.com/v2/REPLACE_ME

# =========================
# Minting / Worker settings
# =========================
# Daily issuance cap in TZS (initially 100,000,000)
DAILY_ISSUANCE_CAP_TZS=100000000

# Worker polling interval
WORKER_POLL_INTERVAL_MS=5000

# Chain selection defaults (optional)
DEFAULT_ISSUANCE_CHAIN=base

# WARNING: Do not commit private keys.
# MVP only: server-side minter key used by the worker to send mint transactions.
MINTER_PRIVATE_KEY=

# Address that receives withdrawal platform fees (minted on burn).
# Used as fallback when a burn is not tied to a partner with its own
# treasury_wallet_address. Leave blank to keep fees as implicit reserve surplus.
PLATFORM_TREASURY_ADDRESS=

# Payout-engine burn signer (/api/cron/process-burns): BURNER_PRIVATE_KEY,
# falling back to MINTER_PRIVATE_KEY. The signer must hold BURNER_ROLE on the
# token or burns fail closed (marked failed with the error, auditable).
# BURNER_PRIVATE_KEY=

# ERC-20 contract addresses per chain
NTZS_CONTRACT_ADDRESS_BASE=
NTZS_CONTRACT_ADDRESS_BNB=

# =========================
# PSP Routing
# =========================
# Controls which PSP handles mobile money (on-ramp + off-ramp).
# Set to 'azampay' only after sandbox testing is complete.
# Card payments always use Snippe regardless of this value.
ACTIVE_MOBILE_PSP=snippe

# =========================
# AzamPay (Mobile Money PSP — active for mobile on-ramp + off-ramp)
# =========================
# Credentials from AzamPay sandbox/production portal
AZAMPAY_APP_NAME=
AZAMPAY_CLIENT_ID=
AZAMPAY_CLIENT_SECRET=
# HMAC secret for verifying AzamPay webhooks (verify signing scheme in sandbox portal)
AZAMPAY_WEBHOOK_SECRET=
# Float bank to disburse from: 'nmb' | 'crdb'
AZAMPAY_BANK_NAME=nmb
# Environment: 'sandbox' | 'production'
AZAMPAY_ENV=sandbox

# =========================
# Snippe (Card payments only — mobile money now handled by AzamPay)
# =========================
# Bearer token for Snippe API (still used for snippe_card payment type)
SNIPPE_API_KEY=
# HMAC secret for verifying Snippe webhooks (starts with whsec_)
SNIPPE_WEBHOOK_SECRET=

# =========================
# WaaS API
# =========================
# Public URL of the nTZS WaaS API (used for webhook URLs + apps/fx → apps/web minting rails)
# Local dev: http://localhost:3000
# Production: https://www.ntzs.co.tz  ← must use www, not bare ntzs.co.tz
NTZS_API_BASE_URL=http://localhost:3000

# AES-256 encryption key for partner HD wallet seeds (64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WAAS_ENCRYPTION_KEY=

# Private key of the platform relayer wallet used to prefund new user wallets with ETH for gas.
# On Base mainnet, 0.0005 ETH per user covers ~500 ERC-20 transfers.
# Generate a dedicated wallet: node -e "const {ethers}=require('ethers');const w=ethers.Wallet.createRandom();console.log('address:',w.address,'key:',w.privateKey)"
# WARNING: Fund this wallet with ETH and keep this key secret.
RELAYER_PRIVATE_KEY=

# Base Sepolia testnet RPC (for WaaS development)
BASE_SEPOLIA_RPC_URL=

# =========================
# Block Explorer API Keys
# =========================
# Get from https://basescan.org/myapikey
BASESCAN_API_KEY=

# =========================
# Internal service-to-service secret (apps/fx → apps/web LP mint endpoint)
# Generate: openssl rand -hex 32
INTERNAL_API_SECRET=

# =========================
# Resend (transactional email for SimpleFX OTP)
# Get API key at https://resend.com
RESEND_API_KEY=
RESEND_FROM=SimpleFX <noreply@ntzs.co.tz>

# =========================
# Merchant Portal
# =========================
# JWT secret for merchant session cookies (generate: openssl rand -hex 32)
# Falls back to FX_JWT_SECRET if not set, but set this explicitly in production.
MERCHANT_JWT_SECRET=

# BIP-39 mnemonic for merchant HD wallet derivation (path m/44'/8453'/2'/0/{index})
# WARNING: Never commit this value. Back it up securely.
MERCHANT_HD_MNEMONIC=

# =========================
# Enterprise Portal (Ramani / Advent)
# =========================
# JWT secret for enterprise session cookies — MUST be different from MERCHANT_JWT_SECRET
# Generate: openssl rand -hex 32
ENTERPRISE_JWT_SECRET=

# =========================
# SimpleFX LP Dashboard
# =========================
# JWT secret for LP session cookies (generate: openssl rand -hex 32)
FX_JWT_SECRET=

# BIP-39 mnemonic for LP wallet HD derivation (path m/44'/8453'/1'/0/{index})
# Generate: node -e "const {ethers}=require('ethers');console.log(ethers.Wallet.createRandom().mnemonic.phrase)"
# WARNING: Never commit this value. Back it up securely.
FX_HD_MNEMONIC=

# SMTP for OTP emails — works with Gmail, Outlook, or any mail server
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use an App Password (not your main password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Optional: override the From address shown to recipients
SMTP_FROM=SimpleFX <noreply@yourdomain.com>
